{#
/**
 * @file
 * Jarvis 3-column layout. col-12 mobile -> stack; col-sm-6 tablet -> 2-up;
 * col-lg-4 desktop -> 3-up. Everything placed inside wraps at each breakpoint.
 */
#}
{% import '@jarvis/jarvis-spacing.html.twig' as jarvis %}
{% set space = jarvis.classes(padding|default('none'), padding_size|default('medium'), margin|default('none'), margin_size|default('medium'), (vertical_padding is defined ? vertical_padding : true), no_padding|default(false)) %}
{% set gap_class = { none: 'g-0', small: 'g-2', normal: 'g-4', large: 'g-5' }[gap|default('normal')] %}
{% set container = (width|default('boxed')) == 'full' ? 'container-fluid' : 'container' %}
{% set bg = background|default('none') %}
{% set has_media = background_image.src is defined and background_image.src %}
{# Media picked shows as the background by default. Choosing a solid colour wins
   (hides the image without clearing the media); clear the media to remove it. #}
{% set bg_img = has_media and (bg == 'none' or bg == 'image') %}
{% set overlay = overlay|default(45) %}
{% set bg_class = bg_img ? 'jarvis-bg jarvis-bg--image' : (bg not in ['none', 'image'] ? 'jarvis-bg jarvis-bg--' ~ bg : '') %}
{% set tc = text_color|default('inherit') %}
{# ADA guard: only apply the override when it meets WCAG AA against this section's
   own background; otherwise fall back to the background's auto-safe text colour. #}
{% set bg_key = bg_img ? 'image' : bg %}
{% set ada_ok = {
  none: ['primary', 'secondary', 'black'],
  primary: ['white'],
  secondary: ['white'],
  bg1: [],
  bg2: [],
  dark: ['white'],
  light: ['secondary', 'black'],
  image: ['white'],
}[bg_key]|default([]) %}
{# Over an image the photo's brightness is unknown, so honour the editor's pick
   (best-effort, like the card) rather than forcing white. On solid backgrounds
   the pick must pass the AA matrix above. #}
{% set text_color_class = (tc != 'inherit' and (bg_img or tc in ada_ok)) ? 'jarvis-text-color--' ~ tc : '' %}
{# Overlay darkens for light text, lightens for dark text, keeping the chosen
   colour readable regardless of the image. Inherit over an image = white text. #}
{% set light_text = (tc == 'white') or (tc == 'inherit') %}
<div class="jarvis-columns jarvis-columns--3 {{ space }} {{ bg_class }} {{ text_color_class }}"{% if bg_img %} style="background-image: url('{{ background_image.src }}');"{% endif %}>
  {% if bg_img %}<div class="jarvis-bg__overlay{{ light_text ? '' : ' jarvis-bg__overlay--light' }}" style="opacity: {{ overlay / 100 }};" aria-hidden="true"></div>{% endif %}
  <div class="{{ container }}">
    <div class="row {{ gap_class }}">
      <div class="col-12 col-sm-6 col-lg-4">
        {{ first }}
      </div>
      <div class="col-12 col-sm-6 col-lg-4">
        {{ second }}
      </div>
      <div class="col-12 col-sm-6 col-lg-4">
        {{ third }}
      </div>
    </div>
  </div>
</div>
