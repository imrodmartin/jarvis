{#
/**
 * @file
 * Jarvis map SDC. Replicates simple_gmap's keyless embed:
 * an iframe pointed at maps.google.com/maps?q=ADDRESS&z=ZOOM&output=embed.
 * No API key required.
 */
#}
{% import '@jarvis/jarvis-spacing.html.twig' as jarvis %}
{% set space = jarvis.classes(padding|default('none'), padding_size|default('medium'), margin|default('none'), margin_size|default('medium'), (vertical_padding is defined ? vertical_padding : true), no_padding|default(false)) %}
{% set zoom = zoom|default(14) %}
{% set height = height|default(400) %}
{% set q = address|url_encode %}
<div class="jarvis-map {{ space }}">
  <iframe
    class="jarvis-map__frame"
    style="height: {{ height }}px;"
    src="https://maps.google.com/maps?q={{ q }}&amp;z={{ zoom }}&amp;output=embed"
    title="{{ address }}"
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"></iframe>
  {% if show_link is not defined or show_link %}
    <div class="jarvis-map__link">
      <a href="https://maps.google.com/maps?q={{ q }}" target="_blank" rel="noopener">{{ link_text|default('View on Google Maps') }}<span class="visually-hidden"> {{ '(opens in new tab)'|t }}</span></a>
    </div>
  {% endif %}
</div>
