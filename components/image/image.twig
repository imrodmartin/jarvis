{#
/**
 * @file
 * Jarvis image SDC.
 */
#}
{% import '@jarvis/jarvis-spacing.html.twig' as jarvis %}
{% set space = jarvis.classes(padding|default('none'), padding_size|default('medium'), margin|default('none'), margin_size|default('medium'), (vertical_padding is defined ? vertical_padding : true), no_padding|default(false)) %}
{% set has_image = image.src is defined and image.src %}
{# Apply a named image style when chosen. jarvis_image_style resolves the file
   from image.src (a public URL) since Canvas gives no stream-wrapper URI here. #}
{% set styled = (image_style is defined and image_style and image_style != 'original') ? image.src|jarvis_image_style(image_style) : null %}
{% set img_src = styled ?: image.src %}
{% set wrapper = full_width ? 'jarvis-image jarvis-image--full' : 'jarvis-image container' %}
{# ponytail: rounded is its own toggle now, decoupled from full_width/padding. #}
{% set round_class = rounded|default(true) ? 'jarvis-image--rounded' : '' %}
<figure class="{{ wrapper }} {{ round_class }} mb-0 {{ space }}">
  {% if has_image %}
    <img src="{{ img_src }}" alt="{{ image.alt }}"{% if not styled and image.width %} width="{{ image.width }}"{% endif %}{% if not styled and image.height %} height="{{ image.height }}"{% endif %} class="img-fluid w-100 jarvis-image__img"{{ priority|default(false) ? ' fetchpriority="high"' : ' loading="lazy"' }}>
  {% endif %}
  {% if caption %}<figcaption class="jarvis-image__caption text-body-secondary small mt-2">{{ caption }}</figcaption>{% endif %}
</figure>
