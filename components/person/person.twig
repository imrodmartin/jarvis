{#
/**
 * @file
 * Jarvis person SDC — portrait, name, position, contact links.
 */
#}
{% import '@jarvis/jarvis-spacing.html.twig' as jarvis %}
{% set space = jarvis.classes(padding|default('none'), padding_size|default('medium'), margin|default('none'), margin_size|default('medium'), (vertical_padding is defined ? vertical_padding : true), no_padding|default(false)) %}
{% set has_image = image.src is defined and image.src %}
{# Crop server-side to the Portrait style; needs the original stream-wrapper URI. #}
{% set portrait = (image_uri is defined and image_uri) ? image_uri|image_style('portrait') : null %}
{% set photo_src = portrait ?: image.src %}
{% set variant = variant|default('card') %}
<div class="jarvis-person jarvis-person--{{ variant }} {{ space }}">
  {% if has_image %}<img src="{{ photo_src }}" alt="{{ image.alt }}" class="jarvis-person__photo mb-3">{% endif %}
  <div class="jarvis-person__details">
  {% if name %}<div class="jarvis-person__name text-primary">{{ name }}</div>{% endif %}
  {% if position %}<div class="jarvis-person__position">{{ position }}</div>{% endif %}
  {% if phone %}<div class="jarvis-person__phone"><a href="tel:{{ phone }}">{{ phone }}</a></div>{% endif %}
  {% if email %}<div class="jarvis-person__email"><a href="mailto:{{ email }}">{{ email }}</a></div>{% endif %}
  {% if link_text and link_href %}<a href="{{ link_href }}" class="btn btn-primary btn-sm mt-2">{{ link_text }}</a>{% endif %}
