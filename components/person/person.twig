  } %}
  {% set has_social = linkedin or x or facebook or instagram or youtube or github %}
  {% if has_social %}
    <div class="jarvis-person__social">
      {% for label, s in socials %}
        {% if s.url %}
          <a href="{{ s.url }}" class="jarvis-person__social-link" aria-label="{{ label }}" target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="{{ s.path }}"/></svg>
          </a>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}
  </div>
</div>
