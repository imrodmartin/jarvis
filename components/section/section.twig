{#
/**
 * @file
 * Jarvis section wrapper SDC with a `content` slot.
 */
#}
{% import '@jarvis/jarvis-spacing.html.twig' as jarvis %}
{% set space = jarvis.classes(padding|default('none'), padding_size|default('medium'), margin|default('none'), margin_size|default('medium'), (vertical_padding is defined ? vertical_padding : true), no_padding|default(false)) %}
{% set width = width|default('normal') %}
{% set bg = bg|default('none') %}
{% set bg_class = bg != 'none' ? 'bg-' ~ bg : '' %}
{% set text_class = (bg == 'dark' or bg == 'primary') ? 'text-white' : '' %}
{% set container = width == 'full' ? 'container-fluid' : 'container' %}
<section class="jarvis-section {{ bg_class }} {{ text_class }} {{ space }}">
  <div class="{{ container }}">
    {{ content }}
  </div>
</section>
